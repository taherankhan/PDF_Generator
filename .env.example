# Google Analytics 4 — Measurement ID from GA4 Admin (format G-XXXXXXXXXX)
# Leave empty to disable tracking in local dev
VITE_GA_MEASUREMENT_ID=

# Supabase — required for cloud share links and contact form
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Alternative name supported by supabaseClient.ts
VITE_SUPABASE_PUBLISHABLE_KEY=
